# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Only needed if your Vercel preview URLs differ from NEXTAUTH_URL fallback.
# NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# --- Google OAuth (https://console.cloud.google.com) ---
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-client-secret

# --- Postgres ---
# Vercel Postgres and Neon auto-inject these when you attach the integration.
# If you're bringing your own Postgres, set both to your connection string
# (pooled + direct). For local dev a single URL is fine for both.
POSTGRES_PRISMA_URL=postgres://user:pass@host/db?pgbouncer=true&connection_limit=1
POSTGRES_URL_NON_POOLING=postgres://user:pass@host/db

# --- Cron auth (set any random string; paste the same into Vercel env) ---
CRON_SECRET=

# --- Absolute site URL for metadata + sitemap (optional) ---
# Falls back to VERCEL_PROJECT_PRODUCTION_URL, then debate-cv.vercel.app.
# NEXT_PUBLIC_SITE_URL=https://debate-cv.vercel.app

# --- Token encryption at rest (32 bytes base64, openssl rand -base64 32) ---
TOKEN_ENCRYPTION_KEY=

# --- Tabbycat scraper ---
# Override the User-Agent sent to Tabbycat hosts. A realistic Chrome UA is the
# default; set this if a particular tournament still blocks the default.
# TABBYCAT_USER_AGENT=Mozilla/5.0 (...)

# --- Admin ---
# Comma-separated list of emails allowed to hit /admin and /api/admin/*.
# Example: ADMIN_EMAIL=you@example.com,colleague@example.com
ADMIN_EMAIL=

# --- Ingest feature flags ---
# When set to "true", every judge assignment parsed from round-results
# pages is persisted (not just the URL owner's panel rows). Lets users
# who never had a private URL for a tournament still pick up their
# judging history when a teammate ingests one. Off by default; the
# extra rows scale with (judges × rounds) per tournament.
# EXTRACT_ALL_JUDGES=true

# --- Scraper proxy (optional, for persistent Cloudflare 403s) ---
# If Cloudflare's bot protection still blocks requests after the browser
# fingerprint + cookie jar, route fetches through ScraperAPI, which rotates
# residential IPs and handles Cloudflare automatically.
# Free tier: 1,000 requests/month. Get a key at https://www.scraperapi.com/
# Leave unset to use direct fetch (default).
# SCRAPER_API_KEY=

# --- Sentry error tracking (optional but recommended for production) ---
# DSN is public-by-design (it ends up in client-side bundles). Setting either
# variable enables Sentry; leaving both unset makes Sentry init a no-op so
# local dev works without a Sentry account. NEXT_PUBLIC_SENTRY_DSN is read by
# the browser bundle; SENTRY_DSN is the server-side fallback.
# NEXT_PUBLIC_SENTRY_DSN=https://....ingest.us.sentry.io/...
# SENTRY_DSN=https://....ingest.us.sentry.io/...
#
# Build-time only: lets `pnpm build` upload source maps to Sentry so prod
# stack traces resolve to your TypeScript source instead of minified output.
# Skip locally (the build plugin no-ops when missing). Set in Vercel for
# production deploys. Generate at: Sentry → User Settings → Auth Tokens
# (scopes: project:read, project:write, project:releases).
# SENTRY_AUTH_TOKEN=
