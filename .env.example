# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Only needed if your Vercel preview URLs differ from NEXTAUTH_URL fallback.
# NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# --- Google OAuth (https://console.cloud.google.com) ---
AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-client-secret

# --- Postgres ---
# Vercel Postgres and Neon auto-inject these when you attach the integration.
# If you're bringing your own Postgres, set both to your connection string
# (pooled + direct). For local dev a single URL is fine for both.
POSTGRES_PRISMA_URL=postgres://user:pass@host/db?pgbouncer=true&connection_limit=1
POSTGRES_URL_NON_POOLING=postgres://user:pass@host/db

# --- Cron auth (set any random string; paste the same into Vercel env) ---
CRON_SECRET=
