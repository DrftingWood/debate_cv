{
  "name": "debate-cv",
  "version": "0.2.0",
  "private": true,
  "description": "Debate CV: Gmail -> Calicotab scrape -> Postgres -> personal tournament history.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
