generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel Postgres / Neon auto-inject both. When bringing your own Postgres,
  // set POSTGRES_PRISMA_URL (pooled; add `?pgbouncer=true&connection_limit=1`
  // if using a pooler) and POSTGRES_URL_NON_POOLING (direct, for migrations).
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// -------------------- NextAuth core --------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// Public CV sharing. publicCvEnabled gates access to /u/<slug>;
  /// publicCvSlug is the slug itself (random by default, optionally
  /// replaced with a user-chosen vanity slug). publicAvatarEnabled lets
  /// a user opt out of showing their Google profile photo on the public
  /// view (per Q10 user-toggle). Defaults: disabled, random slug
  /// generated lazily on first enable, avatar shown.
  publicCvEnabled       Boolean @default(false)
  publicCvSlug          String? @unique
  publicAvatarEnabled   Boolean @default(true)

  accounts          Account[]
  sessions          Session[]
  gmailToken        GmailToken?
  discoveredUrls    DiscoveredUrl[]
  ingestJobs        IngestJob[]
  claimedPersons    Person[]            @relation("ClaimedByUser")
  personRejections  PersonRejection[]
  cvErrorReports    CvErrorReport[]
  notifications     Notification[]
  tagProposals      TagProposal[]
}

/// In-app activity feed surfaced via the notification bell in the header.
/// Per Q16 we deliberately don't send email or push — too easy for those
/// channels to get noisy, and the bell catches engaged users on their next
/// visit. See lib/notifications/write.ts for the helper that creates rows.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  /// Free-form code identifying the event ('ingest_done', 'new_urls_found',
  /// 'report_resolved', 'job_failed_exhausted'). Stored as String rather
  /// than an enum so adding new sources doesn't require a migration.
  kind      String
  title     String
  body      String?   @db.Text
  /// Optional deep-link the user can click to act on the notification
  /// (e.g. /dashboard?filter=failed for a failed-exhausted alert).
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -------------------- Gmail integration --------------------

model GmailToken {
  id                String    @id @default(cuid())
  userId            String    @unique
  accessToken       String    @db.Text
  refreshToken      String?   @db.Text
  expiresAt         DateTime?
  scope             String?
  /// null for legacy rows stored as plaintext; 'v1' for AES-256-GCM.
  encryptionVersion String?
  /// Timestamp of the most recent Gmail scan; used to enforce a per-user
  /// cooldown so users can't hammer /api/ingest/gmail in a tight loop.
  lastScannedAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -------------------- Discovered URLs + ingest queue --------------------

model DiscoveredUrl {
  id                     String    @id @default(cuid())
  userId                 String
  url                    String
  host                   String
  tournamentSlug         String?
  token                  String?
  subject                String?
  messageId              String?
  messageDate            DateTime?
  tournamentId           BigInt?
  registrationPersonId   BigInt?
  registrationName       String?
  lastPreflightError     String?
  ingestedAt             DateTime?
  reingestLocked         Boolean   @default(false)
  createdAt              DateTime  @default(now())

  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament           Tournament? @relation(fields: [tournamentId], references: [id])
  registrationPerson   Person?     @relation("DiscoveredUrlPerson", fields: [registrationPersonId], references: [id], onDelete: SetNull)

  @@unique([userId, url])
  @@index([userId])
  // /cv and /onboarding/names both filter `where: { userId, ingestedAt:
  // ... }` (and tournamentId-not-null); the (userId) index alone forces
  // a row scan on ingestedAt. Compound index turns those queries into an
  // index-only seek.
  @@index([userId, ingestedAt])
}

enum IngestJobStatus {
  pending
  running
  done
  failed
  /// Terminal status for permanently-dead URLs (HTTP 404 on landing,
  /// dead Heroku apps, removed Calicotab tournaments). Not retried by
  /// /api/ingest/retry-failed; surfaced separately from `failed` on the
  /// dashboard so the actionable-failed count stays accurate.
  abandoned
}

model IngestJob {
  id          String          @id @default(cuid())
  userId      String
  url         String
  status      IngestJobStatus @default(pending)
  attempts    Int             @default(0)
  lastError   String?         @db.Text
  scheduledAt DateTime        @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([status, scheduledAt])
}

// -------------------- Tabbycat tournament data --------------------

model Tournament {
  id                   BigInt   @id @default(autoincrement())
  name                 String
  format               String?
  year                 Int?
  totalParticipants    Int?
  totalTeams           Int?
  /// Number of prelim rounds parsed from the landing nav (non-outround
  /// `/results/round/N/` URLs). Authoritative divisor for the speaker
  /// average fallback (`total / prelimRoundCount`) when the speaker tab
  /// only exposes totals — common on AP installs whose tab strips
  /// per-round columns. Null on legacy ingests before this field was
  /// added; CV builder falls back to MAX(TeamResult.roundNumber) in
  /// that case.
  prelimRoundCount     Int?
  /// Approved region tag from lib/tags/vocabulary.ts REGIONS. Tab pages
  /// don't expose location, so this is community-proposed (TagProposal)
  /// and admin-approved — never scraped. Null until someone tags it.
  region               String?
  sourceUrlRaw         String
  fingerprint          String   @unique
  scrapedAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  participants         TournamentParticipant[]
  teamResults          TeamResult[]
  eliminationResults   EliminationResult[]
  judgeAssignments     JudgeAssignment[]
  discoveredUrls       DiscoveredUrl[]
  motions              Motion[]
  tagProposals         TagProposal[]

  @@index([year])
  @@index([format])
}

model Person {
  id                BigInt   @id @default(autoincrement())
  displayName       String
  normalizedName    String   @unique
  claimedByUserId   String?
  createdAt         DateTime @default(now())

  claimedByUser     User?                 @relation("ClaimedByUser", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  participations    TournamentParticipant[]
  judgeAssignments  JudgeAssignment[]
  discoveredOnUrls  DiscoveredUrl[]       @relation("DiscoveredUrlPerson")
  rejections        PersonRejection[]

  @@index([claimedByUserId])
}

/// Records that a user has explicitly said "this Person is not me", so we
/// don't keep prompting them to claim it on the dashboard review panel.
model PersonRejection {
  userId    String
  personId  BigInt
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([userId, personId])
  @@index([personId])
}

model TournamentParticipant {
  id                     BigInt   @id @default(autoincrement())
  tournamentId           BigInt
  personId               BigInt
  teamName               String?
  speakerScoreTotal      Decimal?
  speakerRankOpen        Int?
  speakerRankEsl         Int?
  speakerRankEfl         Int?
  speakerRankOpenDerived Int?
  teamBreakRank          Int?
  judgeTypeTag           String?
  chairedPrelimRounds    Int?
  lastOutroundChaired    String?
  lastOutroundPaneled    String?
  wins                   Int?
  eliminationReached     String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tournament          Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  person              Person               @relation(fields: [personId], references: [id], onDelete: Cascade)
  roles               ParticipantRole[]
  speakerRoundScores  SpeakerRoundScore[]

  @@unique([tournamentId, personId])
  @@index([tournamentId])
  @@index([personId])
}

model ParticipantRole {
  tournamentParticipantId BigInt
  role                    String

  participant TournamentParticipant @relation(fields: [tournamentParticipantId], references: [id], onDelete: Cascade)

  @@id([tournamentParticipantId, role])
}

model SpeakerRoundScore {
  id                      BigInt   @id @default(autoincrement())
  tournamentParticipantId BigInt
  roundNumber             Int
  positionLabel           String?
  score                   Decimal?

  participant TournamentParticipant @relation(fields: [tournamentParticipantId], references: [id], onDelete: Cascade)

  @@unique([tournamentParticipantId, roundNumber, positionLabel])
}

model TeamResult {
  id            BigInt   @id @default(autoincrement())
  tournamentId  BigInt
  teamName      String
  roundNumber   Int?
  rank          Int?
  wins          Int?
  losses        Int?
  points        Decimal?
  /// Team side in this round as shown on the round-results page — "OG" /
  /// "OO" / "CG" / "CO" on BP layouts, or whatever the position/side
  /// column said on two-team formats. Null on roundNumber=0 standings
  /// rows (a tournament-long standing has no side) and on tournaments
  /// ingested before the parser started persisting it (the value was
  /// parsed and discarded for those — re-ingest backfills it). Feeds the
  /// by-position slice on /cv/analytics.
  position      String?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamName, roundNumber])
}

/// One motion as released on the tournament's /tab/motions/ page. Multiple
/// rows per round are legal (motion-per-room formats, replaced motions) —
/// `seq` preserves document order. Slicing analytics by motion *type*
/// (IR / econ / ethics …) is a classification layer on top of this raw
/// text, deliberately not a column yet: classification needs a taxonomy +
/// versioning story and shouldn't block storing the source data.
model Motion {
  id           BigInt  @id @default(autoincrement())
  tournamentId BigInt
  /// Numeric prelim round when the label parsed as one ("Round 3" → 3);
  /// null for outround motions ("Semifinals") and unparseable labels.
  roundNumber  Int?
  roundLabel   String
  /// 0-based document order on the motions page; tiebreaker for rounds
  /// that released more than one motion.
  seq          Int
  text         String  @db.Text
  infoSlide    String? @db.Text
  /// Approved stem tag (THBT/THW/THO/...) from MOTION_TYPES. Auto-suggested
  /// by inferMotionType in the picker, but only written here through an
  /// approved TagProposal — the scraper never sets it.
  motionType   String?
  /// Approved subject-area tag from MOTION_TOPICS. Always human judgement.
  topic        String?

  tournament   Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tagProposals TagProposal[]

  @@unique([tournamentId, roundLabel, seq])
  @@index([tournamentId])
}

enum TagProposalStatus {
  pending
  approved
  rejected
}

/// A user-proposed value for a moderated community tag: a tournament's
/// region, or a motion's type/topic. Tags describe shared facts (the same
/// tournament appears on many CVs), so writes to the canonical columns
/// (Tournament.region, Motion.motionType, Motion.topic) only happen when
/// an admin approves — the proposal row is the moderation queue entry and
/// stays around afterwards as the audit trail of who proposed what.
/// One live proposal per (user, kind, target): the propose API updates the
/// user's existing row back to pending instead of stacking duplicates.
model TagProposal {
  id           String            @id @default(cuid())
  userId       String
  /// 'region' | 'motion_type' | 'motion_topic'. String rather than an enum
  /// (Notification.kind precedent) so new tag kinds don't need a migration.
  kind         String
  tournamentId BigInt
  /// Set for motion_* kinds, null for region.
  motionId     BigInt?
  /// Must be a member of TAG_VALUES[kind] — enforced at the API boundary,
  /// not the DB, so vocabulary edits stay a one-file change.
  value        String
  status       TagProposalStatus @default(pending)
  /// Reviewer note shown back to the proposer (e.g. why it was rejected).
  adminNote    String?
  createdAt    DateTime          @default(now())
  reviewedAt   DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  motion     Motion?    @relation(fields: [motionId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, tournamentId])
  @@index([motionId])
}

model EliminationResult {
  id           BigInt @id @default(autoincrement())
  tournamentId BigInt
  stage        String
  entityType   String
  entityName   String
  result       String?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, stage, entityType, entityName])
}

model JudgeAssignment {
  id           BigInt @id @default(autoincrement())
  tournamentId BigInt
  personId     BigInt
  stage        String?
  panelRole    String?
  roundNumber  Int?
  /// Where this assignment came from. 'landing' = parsed from the URL
  /// owner's private-URL Debates card (authoritative for that one judge).
  /// 'round_results' = parsed from per-round results pages (covers every
  /// judge on every panel; only enabled when EXTRACT_ALL_JUDGES is set).
  /// Lets prepareTournamentWideRefresh selectively clear round-results
  /// entries (which stale the moment a tournament re-publishes panels)
  /// without touching landing-derived entries (which the URL owner's
  /// own re-ingest will atomically refresh in recordJudgeRoundsFromLanding).
  source       String  @default("landing")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  person     Person     @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, personId, stage, panelRole, roundNumber])
  @@index([tournamentId, source])
}

// -------------------- Beta feedback --------------------

enum CvReportStatus {
  open
  acknowledged
  fixed
  wont_fix
}

model CvErrorReport {
  id            String         @id @default(cuid())
  userId        String
  tournamentIds String[]       @default([])
  /// Structured issue codes the user picked from the report modal — e.g.
  /// "wrong_teammate", "wrong_speaker_rank", "wrong_identity". Optional;
  /// freeform comment in `comment` is the fallback.
  categories    String[]       @default([])
  comment       String         @db.Text
  /// Closed-loop status surfaced on /settings/reports so users can see
  /// whether their report was acknowledged / fixed / declined.
  status        CvReportStatus @default(open)
  /// Admin-visible note attached when transitioning status (e.g. "fixed by
  /// PR #x" or "won't fix because Y"). Surfaced read-only on the user's
  /// reports page once status moves off `open`.
  adminNote     String?        @db.Text
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([resolvedAt])
  @@index([status])
}

// -------------------- Provenance + parser versioning --------------------

/// One row per (url, contentHash) fetched from a Tabbycat page. Dedup'd on
/// content hash so re-fetching an unchanged page is free after the first time.
model SourceDocument {
  id            String      @id @default(cuid())
  url           String
  status        Int
  contentHash   String
  contentLength Int
  /// Gzipped raw HTML of the fetched page. Added 2026-06: before this we
  /// kept only the hash, which meant every new parsed field (motions,
  /// team positions) forced a full re-scrape of every tournament — and
  /// dead Heroku tabs made that lossy. With bodies retained, future
  /// parser additions can re-derive from storage. Null on rows fetched
  /// before the column existed and on oversized pages (see
  /// MAX_STORED_BODY_BYTES in fetch.ts). Dedup'd by the (url,
  /// contentHash) unique, so unchanged pages cost one stored copy.
  bodyGzip      Bytes?
  fetchedAt     DateTime    @default(now())

  parserRuns    ParserRun[]

  @@unique([url, contentHash])
  @@index([url])
  @@index([fetchedAt])
}

/// Records each parser invocation for a SourceDocument. Lets us re-parse
/// old snapshots when PARSER_VERSION bumps and track selector-miss warnings
/// as a production signal.
model ParserRun {
  id               String         @id @default(cuid())
  sourceDocumentId String
  parserName       String
  parserVersion    String
  success          Boolean
  warnings         String[]       @default([])
  durationMs       Int?
  createdAt        DateTime       @default(now())

  sourceDocument   SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)

  @@index([sourceDocumentId])
  @@index([parserVersion, parserName])
}
